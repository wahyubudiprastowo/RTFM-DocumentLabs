# =========================
# Evolution API Connection
# =========================
EVO_BASE_URL=http://0.0.0.0:8080
EVO_API_KEY=MASUKAN API KAMU
EVO_INSTANCE=gudangpro

# =========================
# Safety guard
# =========================
# 1 = simulasi, tidak benar-benar kirim
# 0 = benar-benar kirim
DRY_RUN=0

# harus 1 supaya benar-benar boleh kirim
ENABLE_SENDING=1

# =========================
# Environment / Campaign
# =========================
ENV_NAME=prod
CAMPAIGN_ID=champaig-2026-followup-01

# Hari yang diizinkan untuk campaign ini
# contoh: MON,TUE,WED,THU,FRI,SAT
CAMPAIGN_ALLOWED_DAYS=MON,TUE,WED,THU,FRI,SAT,SUN

# =========================
# Data Source
# =========================
CONTACTS_CSV=contacts.csv
CSV_DELIMITER=;
PHONE_COLUMN=phone
NAME_COLUMN=name
OPT_IN_COLUMN=opt_in
DNC_COLUMN=do_not_contact
OPT_IN_TRUE=yes,y,true,1
DNC_TRUE=yes,y,true,1

PHONE_MIN_LEN=10
PHONE_MAX_LEN=16

DB_PATH=broadcast.sqlite
LOG_CSV=send_log.csv
LOCK_FILE_PATH=/tmp/evo_broadcast2.lock

# =========================
# Message Templates
# =========================
# mode:
# - round_robin
# - random
# - weighted_random
TEMPLATE_SELECTION=weighted_random

# format: path:weight,path:weight,...
# weight dipakai jika TEMPLATE_SELECTION=weighted_random
# kalau round_robin/random, urutan file tetap dibaca dari kiri ke kanan
TEMPLATE_SPECS=templates/prod_a.txt:20,templates/prod_b.txt:20,templates/prod_c.txt:20,templates/prod_d.txt:20,templates/prod_e.txt:20

# =========================
# Evolution send behavior
# =========================
REQUEST_TIMEOUT_S=30
HTTP_RETRY_COUNT=2
HTTP_RETRY_BACKOFF_S=2

# delay internal sendText (ms)
EVO_SENDTEXT_DELAY_MS=1000

# 1 = tampilkan preview link kalau ada URL
EVO_LINK_PREVIEW=1

# optional: kirim presence typing dulu
EVO_USE_PRESENCE=1
EVO_PRESENCE_TYPE=composing
EVO_PRESENCE_DELAY_MS=1200
EVO_POST_PRESENCE_SLEEP_S=0.3

# =========================
# Resume / Retry / Queue
# =========================
MAX_ATTEMPTS=5
RETRY_FAILED=1

# row IN_PROGRESS yang lebih tua dari ini dianggap stale lalu dibalikin ke PENDING
LOCK_STALE_MINUTES=20

# jika FAILED dengan kode / error di bawah ini, langsung dianggap permanent fail
# dan tidak akan dicoba lagi
PERMFAIL_HTTP_CODES=400,401,403,404
PERMFAIL_ERROR_SUBSTRINGS=invalid number,not on whatsapp,unauthorized,forbidden,not found,bad request

# =========================
# Working hours per day
# =========================
BUSINESS_HOURS_ENABLED=1

# 0 = exit jika di luar window
# 1 = tunggu sampai window berikutnya
WAIT_FOR_WINDOW=1

BUSINESS_MON_ENABLED=1
BUSINESS_MON_START=02:00
BUSINESS_MON_END=21:00

BUSINESS_TUE_ENABLED=1
BUSINESS_TUE_START=02:00
BUSINESS_TUE_END=21:00

BUSINESS_WED_ENABLED=1
BUSINESS_WED_START=02:00
BUSINESS_WED_END=21:00

BUSINESS_THU_ENABLED=1
BUSINESS_THU_START=02:00
BUSINESS_THU_END=21:00

BUSINESS_FRI_ENABLED=1
BUSINESS_FRI_START=02:00
BUSINESS_FRI_END=21:00

BUSINESS_SAT_ENABLED=1
BUSINESS_SAT_START=02:00
BUSINESS_SAT_END=21:00

BUSINESS_SUN_ENABLED=1
BUSINESS_SUN_START=02:00
BUSINESS_SUN_END=21:00

# =========================
# Pacing operasional
# smoothing beban, bukan untuk menyamarkan bot
# =========================

# jeda antar message
PER_MSG_MIN_S=300
PER_MSG_MAX_S=650

# jumlah message per batch
BATCH_SIZE_MIN=10
BATCH_SIZE_MAX=15

# jeda antar batch
BATCH_MIN_S=900
BATCH_MAX_S=1800

# maksimum item queue yang diproses per sekali run
MAX_PER_RUN=100

# =========================
# Blacklist
# =========================
BLACKLIST_ENABLED=1
BLACKLIST_FILE=blacklist.txt

# txt / csv / auto
BLACKLIST_FILE_TYPE=auto

# kalau file blacklist csv
BLACKLIST_CSV_DELIMITER=;
BLACKLIST_CSV_COLUMN=phone

# =========================
# Failed export
# =========================
FAILED_EXPORT_AUTO=1
FAILED_EXPORT_CSV=failed_export.csv
FAILED_EXPORT_TIMESTAMPED=1

# status yang akan diexport
FAILED_EXPORT_STATUSES=FAILED,SKIPPED_PERMFAIL,SKIPPED_BLACKLIST

# =========================
# Telegram report
# =========================
REPORT_TELEGRAM_ENABLED=0
REPORT_TELEGRAM_BOT_TOKEN=
REPORT_TELEGRAM_CHAT_ID=

# =========================
# Discord report
# =========================
REPORT_DISCORD_ENABLED=0
REPORT_DISCORD_WEBHOOK_URL=
